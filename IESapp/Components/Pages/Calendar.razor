@page "/calendar"

<div class="dashboard-header">
    <h3>Calendar</h3>
</div>

<div class="dashboard-card" style="height: calc(100vh - 200px);">
    <!-- 
        Since we skipped full Google OAuth for the prototype, 
        we embed a generic public Google Calendar iframe to demonstrate the UI layout. 
    -->
    <iframe src="https://calendar.google.com/calendar/embed?src=en.philippines%23holiday%40group.v.calendar.google.com&ctz=Asia%2FManila" 
            style="border: 0; width: 100%; height: 100%; border-radius: 8px;" 
            frameborder="0" 
            scrolling="no">
    </iframe>
</div>
