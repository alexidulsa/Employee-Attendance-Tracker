@page "/employees"
@implements IDisposable
@inject IESapp.Services.GoogleSheetsService SheetsService
@inject IESapp.Services.AppState AppState

<div class="dashboard-header">
    <div style="display: flex; align-items: center; gap: 10px;">
        <h3>Employee List</h3>
        <button class="eye-toggle-btn" @onclick="() => isHidden = !isHidden"
            title="@(isHidden ? "Show" : "Hide") employee data">
            @if (isHidden)
             {
                <!-- Eye Closed Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" 
                    fill="currentColor" viewBox="0 0 16 16">
                    <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 
                    1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 
                    1.12-1.465 1.755q-.247.248-.517.486z"/>
                    <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 
                    2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 
                    2.5 0 0 0 2.829 2.829"/>
                    <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 
                    1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 
                    2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 
                    2.641-3.238l.708.709z"/>
                    <path d="M13.646 14.354l-12-12 .708-.708 12 12z"/>
                </svg>
            }
            else
            {
                <!-- Eye Open Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" 
                    fill="currentColor" viewBox="0 0 16 16">
                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 
                    8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 
                    5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 
                    1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 
                    13 0 0 1 1.172 8z"/>
                    <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/>
                </svg>
            }
        </button>
    </div>
    <div style="display: flex; gap: 10px;">
        <button class="btn btn-primary" @onclick="() => showAddPopup = true" disabled="@(!AppState.IsAdmin)"
            title="@(!AppState.IsAdmin ? "Admin login required" : "Add a new employee")">
            + Add
        </button>
        <button class="btn btn-warning" @onclick="() => showEditPopup = true"
            disabled="@(selectedEmployee == null || !AppState.IsAdmin)"
            title="@(!AppState.IsAdmin ? "Admin login required" : selectedEmployee == null ? "Select an employee first" : "Edit selected employee")">
            ✎ Edit
        </button>
        <button class="btn btn-danger" @onclick="() => showRemovePopup = true" disabled="@(!AppState.IsAdmin)"
            title="@(!AppState.IsAdmin ? "Admin login required" : "Remove an employee")">
            🗑 Remove
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        <strong>Error connecting to Google Sheets:</strong> @errorMessage
        <br /><small>Please ensure your Spreadsheet ID is correct and the bot email has Editor access.</small>
    </div>
}
else if (isLoading)
{
    <p>Loading employees...</p>
}
else
{
    <div class="dashboard-card pt-0">
        <div class="table-responsive">
            <table class="table modern-table">
                <thead>
                    <tr>
                        <th>GUID</th>
                        <th>IES_ID</th>
                        <th>Name</th>
                        <th>Birthday</th>
                        <th>Age</th>
                        <th>Sex</th>
                        <th>Job Position</th>
                        <th>Status</th>
                        <th>Total Hrs</th>
                    </tr>
                </thead>
                <tbody style="opacity: @(isHidden ? "0.05" : "1"); transition: opacity 0.3s;">
                    @foreach (var emp in employees)
                    {
                        var status = GetEmployeeStatus(emp.Id);
                        var isSelected = selectedEmployee?.Id == emp.Id;
                        <tr class="@(isSelected ? "selected-row" : "")" @onclick="() => selectedEmployee = AppState.IsAdmin ? (selectedEmployee?.Id == emp.Id ? null : emp) : null"
                            style="cursor: pointer;">
                            <td>@emp.Id</td>
                            <td>@(string.IsNullOrEmpty(emp.IesId) ? "-" : emp.IesId)</td>
                            <td>@emp.Name</td>
                            <td>@(emp.Birthday == DateOnly.MinValue ? "-" : emp.Birthday.ToString("MM/dd/yyyy"))</td>
                            <td>@(emp.Birthday == DateOnly.MinValue ? "-" : emp.Age.ToString())</td>
                            <td>@emp.Sex</td>
                            <td>@emp.JobPosition</td>
                            <td>
                                <span class="status-badge status-@status.Replace(" ", "").ToLower()">
                                    @status
                                </span>
                            </td>
                            <td>@GetTotalHours(emp.Id)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<IESapp.Components.Shared.AddEmployeePopup @bind-IsVisible="showAddPopup" OnEmployeeAdded="LoadData" />
<IESapp.Components.Shared.RemoveEmployeePopup @bind-IsVisible="showRemovePopup" OnEmployeeRemoved="LoadData"
    Employees="employees" />
<IESapp.Components.Shared.EditEmployeePopup @bind-IsVisible="showEditPopup" Employee="selectedEmployee"
    OnEmployeeUpdated="LoadData" />

@code {
    private List<IESapp.Models.Employee> employees = new();
    private List<IESapp.Models.TimeLog> timeLogs = new();
    private bool isLoading = true;
    private bool showAddPopup = false;
    private bool showRemovePopup = false;
    private bool showEditPopup = false;
    private bool isHidden = false;
    private IESapp.Models.Employee? selectedEmployee = null;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        AppState.OnTimeLogsUpdated += ReLoadData;
        await LoadData();
    }

    private async void ReLoadData()
    {
        await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = "";
        try
        {
            employees = await SheetsService.GetEmployeesAsync();
            timeLogs = await SheetsService.GetTimeLogsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            _ = SheetsService.AppendErrorLogAsync(AppState.SessionId, $"[EmployeeList.LoadData] {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetEmployeeStatus(string empId)
    {
        var log = timeLogs.FirstOrDefault(l => l.EmployeeId == empId && (l.Status == "On Duty" || l.Status == "Shift Done"));
        return log?.Status ?? "Not Started";
    }

    private string GetTotalHours(string empId)
    {
        // Sum all TotalHrs entries for this employee (handles duplicates/multiple shifts)
        var totalMinutes = 0;
        foreach (var log in timeLogs.Where(l => l.EmployeeId == empId && !string.IsNullOrEmpty(l.TotalHrs)))
        {
            if (TimeSpan.TryParse(log.TotalHrs, out TimeSpan ts))
                totalMinutes += (int)ts.TotalMinutes;
        }
        if (totalMinutes == 0) return " --:--";
        var total = TimeSpan.FromMinutes(totalMinutes);
        return $"{(int)total.TotalHours:D2}:{total.Minutes:D2}";
    }

    public void Dispose()
    {
        AppState.OnTimeLogsUpdated -= ReLoadData;
    }
}
